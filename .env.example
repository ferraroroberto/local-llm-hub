# Local LLM Hub — environment variables. Copy to .env (gitignored) and
# edit. None of these are *required* for the hub to boot; sensible
# defaults apply when absent.

# ----------------------------------------------------------------- host
# Override the host's identity (otherwise `socket.gethostname()` is used
# to pick the row from config/models.yaml).
# LOCAL_LLM_HUB_HOST=pc-cuda

# ----------------------------------------------------------------- remote hub bootstrap/sync (#181)
# Private key for the dedicated local-llm-hub-remote-ctl SSH keypair used
# by POST /admin/api/hosts/{host_id}/bootstrap and .../sync. Never the
# general-purpose interactive key — this one is restricted server-side to
# a forced command (mac/bin/hub-remote-ctl.sh) that only allows
# "bootstrap"/"sync", nothing else. Unset = those endpoints 501.
# LOCAL_LLM_HUB_SSH_KEY=C:\Users\rober\.ssh\local-llm-hub-remote-ctl

# ----------------------------------------------------------------- OpenTelemetry / Langfuse (issue #4)
#
# The hub emits traces + metrics via OTLP/HTTP to the Langfuse stack
# started by `start_langfuse.bat`. The endpoint is derived from
# LANGFUSE_HOST below — Langfuse v3 receives spans at
# /api/public/otel/v1/traces under its main web port and authenticates
# via Basic auth against the project's public + secret key pair.
#
# Set OTEL_SDK_DISABLED=true to turn telemetry off entirely (the hub
# still works; the /admin Telemetry tab will show "stack offline").

OTEL_SDK_DISABLED=false
OTEL_SERVICE_NAME=local-llm-hub

# Capture mode for prompts / completions. Default = capture raw text
# (this is a personal localhost hub; debug value is high). Flip to "true"
# to store BLAKE2b hashes instead — set this any time the hub may be
# reached from somewhere less trusted than your own LAN.
OTEL_HASH_PROMPTS=false

# Langfuse — both the OTel exporter AND the feedback endpoint authenticate
# with these. Produced in the Langfuse UI after first-run project creation.
# Without them, Langfuse rejects every span the hub emits ("Trace not found"
# when clicking the deep-link from the Telemetry tab).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# LANGFUSE_HOST — the URL the HUB uses internally to reach Langfuse. Always
# localhost-ish on the same machine; do NOT set this to your LAN / Tailscale
# / Cloudflare hostname.
LANGFUSE_HOST=http://localhost:3000

# LANGFUSE_PUBLIC_URL — optional override for the Langfuse URL the BROWSER
# opens when the user clicks a deep-link in the Telemetry tab. Leave blank
# for localhost / LAN / Tailscale (the SPA derives Langfuse's URL from the
# same hostname the admin SPA was loaded from, swapping port 8000 -> 3000).
# Set this only when the hub is accessed via Cloudflare Tunnel or a custom
# domain — then put your tunneled Langfuse hostname here, e.g.
#   LANGFUSE_PUBLIC_URL=https://langfuse.example.com
LANGFUSE_PUBLIC_URL=

# ----------------------------------------------------------------- GitHub Copilot billing (issue #231)
# Fine-grained GitHub PAT with the "Plan: read-only" user permission, used
# only to fetch the authoritative per-day x per-model AI Credit spend for
# the Code tab's "Copilot credits (official)" card. Unset = that card shows
# "not configured" — the rest of the Copilot vendor data (CLI + VS Code
# session logs) works fine without it.
# GITHUB_COPILOT_BILLING_PAT=
