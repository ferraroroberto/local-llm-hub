%% docs/architecture.mmd — local-llm-hub's own internal structure.
%% Hand-authored, not generated — companion to the fleet-wide convention in
%% ferraroroberto/fleet-config#256 (see that repo's own docs/architecture.mmd
%% for the reference dogfood). This is deliberately smaller than
%% docs/project-structure.md's three detailed diagrams (component/module/
%% sequence) — it's the one-glance map; project-structure.md stays the deep
%% reference. Update this diagram in the same PR as any material structural
%% change (a backend added/removed, a router moved, a process manager
%% relocated) — same anti-staleness contract as this repo's own `.fleet.toml`
%% `description` field.

flowchart TB
  subgraph entry["Entry points"]
    TRAY["tray.bat / tray/tray.py\npystray icon + Cloudflare tunnel"]
    RUNHUB["run_hub.bat / .sh\npython -m src.run_backend hub"]
    RUNMODEL["launchers/run_*.bat / .sh\npython -m src.run_backend <model_id>"]
  end

  subgraph core["src/server.py — FastAPI hub (:8000)"]
    SRV["POST /v1/messages (Anthropic shape)\nPOST /v1/chat/completions (OpenAI shape)\nGET /v1/models · /health · /info\nGET / -> 307 /admin/"]
    CHATT["chat_translation.py\nschemas + media extraction + prompt flatten +\nper-backend dispatch (split out of server.py, issue #245)"]
    LIFECYCLE["server_lifecycle.py\nstartup/shutdown hooks + resource sampler +\nstartup-profile autostart (backends/Docker/\nLangfuse, issue #265) +\nfleet reconcile loop (boot + ~5min, issue #353)"]
    REG["model_registry.py\nModel rows from config/models.yaml +\nhub_peer_ids() (hub-running peers, #372)"]
    HOSTP["host_profile.py\nresolve active host"]
    OTELRECV["server_otel_receiver.py\nPOST /v1/metrics (OTLP receiver, issue #68)"]
    SVC["services.py\nDocker/Langfuse probe + launch_stack,\npeer health probe (issue #27, generalized #372)"]
  end
  TRAY --> SRV
  RUNHUB --> SRV
  SRV --> CHATT
  SRV --> LIFECYCLE
  SRV --> REG
  REG --> HOSTP
  LIFECYCLE --> SVC
  LIFECYCLE --> REMOTEBOOT
  SVC --> LANGFUSE
  SVC -->|probe + launch| AGENTSVIEW

  subgraph routing["Backend wrappers"]
    CLAUDECLI["claude_cli.py\nsubprocess.run claude -p"]
    GEMINICLI["gemini_cli.py\nConPTY (pywinpty) -> agy"]
    OAIUP["openai_upstream.py\nhttpx -> llama-server /v1"]
    AUDIOR["server_audio.py\n/v1/audio/* proxy"]
    IMAGESR["server_images.py\n/v1/images/* proxy"]
  end
  CHATT -->|backend=claude| CLAUDECLI
  CHATT -->|backend=gemini| GEMINICLI
  CHATT -->|backend=openai| OAIUP
  SRV -->|chat_completions direct dispatch| CLAUDECLI
  SRV -->|chat_completions direct dispatch| GEMINICLI
  SRV -->|chat_completions direct dispatch| OAIUP
  SRV --> AUDIOR
  SRV --> IMAGESR
  SRV --> OTELRECV
  IMAGESR -->|call_gemini_image| GEMINICLI

  subgraph multihost["Multi-host (Mac Mini + gaming peers, issue #181/#372)"]
    REMOTEPROXY["remote_proxy.py\nresolve owning host's own base_url\nfor a model this host doesn't own"]
    REMOTEBOOT["remote_bootstrap.py\nSSH forced-command verbs: bootstrap/sync\n(dead peer hub, #181; OS-agnostic tower side —\nmac/ + linux/ bin/hub-remote-ctl.sh dispatchers, #368)\n+ general-SSH reboot/shutdown (#309/#311)"]
    MACHINECON["machine_console.py\nMachines-tab console (#309): host inventory\n+ per-machine card assembly + RDP gen"]
    REMOTESTATS["remote_stats.py\nTCP liveness (is the box on?) + general-SSH\nCPU/RAM/GPU/disk/uptime snapshot (#309)"]
    SSHTERM["ssh_terminal.py\nin-browser SSH terminal (#309): drives\napp-launcher's session-host over loopback"]
    DIAG["diagnostics/ (issue #315)\nsampler (in-hub asyncio task, no resident proc) ·\nattribution (process -> fleet app + ports, per-OS) ·\nrules (health verdict) · coverage (measured vs blind, #322) ·\nreport (summary/drift/md) · store (SQLite) ·\ningest (foreign portable capture, #316)"]
    PARAKEETSRV["parakeet_server.py\nOpenAI-shape ASR shim ->\nFluidAudio Parakeet CoreML worker"]
    FLEETREC["fleet_reconcile.py (issue #353)\nadditive convergence: wake offline can-ssh\nsatellite -> write-through its startup_profile\n-> start placed-but-not-running models\n(fleet_placement.py = desired-state file)"]
    WOL["wake_on_lan.py (issue #356)\nmagic-packet builder + UDP broadcast\n(true power-on beneath the SSH bootstrap)"]
  end
  CHATT --> REMOTEPROXY
  SRV --> REMOTEPROXY
  AUDIOR --> REMOTEPROXY
  LIFECYCLE -->|periodic reconcile| FLEETREC
  FLEETREC -->|wake unreachable satellite| REMOTEBOOT
  FLEETREC -->|WOL cold satellite first (#364)| WOL
  FLEETREC -->|start local placed models| BACKPROC
  FLEETREC -->|peer profile-write + model start| MACMINI
  FLEETREC -.reads.-> FLEETCFG
  WROUT -->|models tab proxy check| REMOTEPROXY
  WROUT -->|hosts tab| REMOTEBOOT
  WROUT -->|machines tab| MACHINECON
  WROUT -->|machines: reboot/shutdown| REMOTEBOOT
  WROUT -->|machines: wake| WOL
  WOL -->|UDP :9 broadcast to wired-NIC MAC| GAMING
  WROUT -->|machines: SSH terminal WS proxy| SSHTERM
  MACHINECON --> REMOTEBOOT
  MACHINECON --> REMOTESTATS
  WROUT -->|machines: diagnostics modal| DIAG
  WROUT -->|POST diagnostics/ingest| DIAG
  LIFECYCLE -->|close orphan runs + arm scheduled snapshot| DIAG
  DIAG -.reads.-> DIAGCFG
  DIAG -.writes.-> DIAGDB
  PORTCAP["scripts/portable_capture.py\nstandalone psutil sampler, SSH-delivered,\nno src/ imports (issue #316)"]
  OPENCLAW -.ssh: run + capture raw JSON.-> PORTCAP
  PORTCAP -->|raw capture ingested centrally| DIAG
  REMOTESTATS -->|TCP :22 + read-only ssh| MACMINI
  REMOTESTATS -->|TCP :22 + read-only ssh| OPENCLAW
  REMOTESTATS -->|TCP :22 + read-only ssh| GAMING
  SSHTERM -->|POST /sessions + WS| SESSIONHOST
  REMOTEBOOT -->|general-SSH reboot/shutdown| OPENCLAW
  REMOTEBOOT -->|general-SSH reboot/shutdown| GAMING

  subgraph procmgr["Process managers"]
    SUPERVISOR["process_supervisor.py\nshared subprocess start/stop workflow"]
    SERVPROC["server_process.py\nhub's own Popen + kill-port"]
    BACKPROC["backend_process.py\nper-model Popen: llama-server ·\nwhisper-server · tts_server shim ·\nparakeet_server"]
    WATCHDOG["_respawn_watchdog.py\ndetached: wait for parent PID to die,\nthen relaunch (stdlib-only, issue #198)"]
  end
  RUNMODEL --> BACKPROC
  TRAY -->|Models submenu| BACKPROC
  TRAY -->|Restart hub| SERVPROC
  SERVPROC --> SUPERVISOR
  BACKPROC --> SUPERVISOR
  BACKPROC -.spawns.-> PARAKEETSRV

  subgraph ext["External processes / subscriptions"]
    CLAUDEBIN["claude -p CLI\n(Claude Code subscription)"]
    AGYBIN["agy Antigravity CLI\n(Google AI Pro/Ultra subscription)"]
    LLAMA["llama-server (vendor/llama.cpp)\nQwen3.5-4B :8088 · Gemma4-26B-A4B :8087\n+ ad-hoc :8081/:8082/:8086"]
    TTS["tts_engines/ (piper · kokoro · chatterbox)\nvia tts_server.py shim :8092/:8095/:8096\n(orpheus moved to gaming, #323)"]
    CCHOST["Any host Claude Code CLI session\n(incl. sub-agents — CLAUDE_CODE_ENABLE_TELEMETRY)"]
    MACMINI["Mac Mini (mac-mini-m4, 192.168.0.14)\npeer local-llm-hub install :8000\nowns qwen3.5-9b · parakeet-tdt-0.6b-v3"]
    PARAKEETWORKER["mac/parakeet-worker/ (Swift, ANE)\nFluidAudio Parakeet TDT 0.6B v3\nvia CoreML"]
    AGENTSVIEW["AgentsView server (optional, external)\nkenn-io/agentsview · :8080 (issue #280)"]
    SESSIONHOST["app-launcher session-host (:8446)\nloopback ConPTY/WS engine reused for the\nSSH terminal — needs app-launcher#558"]
    OPENCLAW["OpenClaw (Linux laptop, 192.168.0.239)\nmanaged-only machine: SSH reboot/shutdown/\nuptime + RDP (Machines console, #309)"]
    GAMING["gaming (Ryzen Linux satellite, 192.168.0.16)\npeer local-llm-hub install :8000 (systemd, #341;\ninstall.py + bootstrap/sync parity #368)\nowns all whisper.cpp STT (turbo/translate/vanilla)\n+ orpheus (TTS) — #323/#370\nGTX 1070, CUDA sm_61 builds"]
  end
  CLAUDECLI --> CLAUDEBIN
  GEMINICLI --> AGYBIN
  OAIUP --> LLAMA
  AUDIOR --> TTS
  BACKPROC -.spawns.-> LLAMA
  BACKPROC -.spawns.-> TTS
  CCHOST -->|OTLP/HTTP :8000/v1/metrics| OTELRECV
  REMOTEPROXY -->|forwards verbatim to owning :8000| MACMINI
  REMOTEPROXY -->|all whisper.cpp STT + orpheus to owning :8000| GAMING
  REMOTEBOOT -->|SSH forced-command bootstrap/sync| MACMINI
  REMOTEBOOT -->|SSH forced-command bootstrap/sync (systemctl, #368)| GAMING
  PARAKEETSRV -.spawns.-> PARAKEETWORKER

  subgraph admin["app_web/ — admin SPA, sub-app mounted at /admin"]
    WSRV["server.py\ncreate_app() + versioned static"]
    WROUT["routers/\nhub · models · startup_profile · fleet_placement · roles ·\nplayground · services · telemetry · code_usage ·\nglossary · hosts · machines · diagnostics · auth ·\nwebauthn · version · misc"]
    WSTATIC["static/\nindex.html SPA + per-tab JS/CSS"]
  end
  SRV -.mounts.-> WSRV
  WSRV --> WROUT
  WSRV --> WSTATIC
  WROUT -->|hub tab| SERVPROC
  WROUT -->|hub restart| WATCHDOG
  WROUT -->|models tab| BACKPROC
  WROUT -->|fleet-placement tab: PATCH/reconcile| FLEETREC
  WROUT -.reads/writes.-> FLEETCFG
  WROUT -->|playground tab| SRV

  subgraph obs["Observability"]
    HUBLOG["hub_log.py / hub_observability.py\nin-memory ring -> admin Hub tab"]
    OTEL["observability.py\nOTel bootstrap (traces + genai metrics)"]
    CCOTEL["claude_code_otel.py\nOTLP parse + JSONL persist + rollups (issue #68)"]
  end
  SRV --> HUBLOG
  SRV --> OTEL
  OTEL -->|OTLP/gRPC| LANGFUSE["Langfuse stack\ndocker/langfuse/docker-compose.yml"]
  OTELRECV --> CCOTEL
  WROUT -->|OTel tab: Claude Code panel| CCOTEL
  WROUT -->|Code tab: AGY vendor via src/agentsview_usage.py| AGENTSVIEW

  subgraph cfg["Config + data"]
    MODELSYAML[("config/models.yaml\nhosts (+ vram_mb ceiling) + model registry\n(+ est_vram_mb footprint) — fleet-placement\ngrid capacity warnings (issue #375)")]
    WEBCFG[("config/webapp_config.json\nauth token + allowlist")]
    GLOSSARY[("config/transcription_glossary.json\nASR post-processing rules")]
    STARTUPCFG[("config/startup_profile.json (gitignored; .example committed)\ndocker/langfuse/agentsview/models — each host's own autostart\n(issues #265, #304; mac_mini_sync retired #374)")]
    FLEETCFG[("config/fleet_placement.json (gitignored; .example committed)\n{host_id: [model_id]} — sole cross-host desired state;\npeer wake/sync owned by reconcile (issues #353, #374)")]
    MODELSDIR["models/ (gitignored)\nGGUF + whisper weights"]
    USAGEHIST[("data/code_usage_history.json\ndaily usage rollups — outlive\ntranscript pruning (issue #280)")]
    DIAGCFG[("config/diagnostics_apps.json + _rules.json (committed)\nprocess->app attribution + health thresholds;\nconfig/diagnostics_settings.json (gitignored)\nretention + scheduled snapshot (issue #315)")]
    DIAGDB[("data/diagnostics.db (gitignored)\nSQLite capture store: runs · samples ·\nprocess_samples · ports · verdicts (issue #315)")]
  end
  REG -.reads.-> MODELSYAML
  HOSTP -.reads.-> MODELSYAML
  WSRV -.reads.-> WEBCFG
  AUDIOR -.reads.-> GLOSSARY
  BACKPROC -.reads.-> MODELSDIR
  REG -.reads.-> STARTUPCFG
  LIFECYCLE -.reads.-> STARTUPCFG
  WROUT -.reads/writes.-> STARTUPCFG
  WROUT -.reads/writes.-> USAGEHIST

  subgraph tests["tests/ + scripts/"]
    UNITTESTS["tests/*.py\npytest, TestClient + monkeypatched CLIs"]
    E2E["tests/e2e/\nPlaywright against the real admin SPA"]
    SMOKE["scripts/smoke_test.py\nreal HTTP against a running hub"]
    INSTALL["src/install.py\ncheck/fix CLI"]
  end
  UNITTESTS --> SRV
  E2E --> WSRV
  SMOKE --> SRV
  INSTALL --> BACKPROC

  classDef ext fill:#2a2f3a,stroke:#555,color:#eee
  classDef hub fill:#1d2a1d,stroke:#4a7,color:#eee
  classDef ui fill:#2a1d2a,stroke:#a47,color:#eee
  classDef cfgnode fill:#2a281d,stroke:#a94,color:#eee
  class ext ext
  class core hub
  class admin ui
  class cfg cfgnode
